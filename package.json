{
  "name": "sheet-to-tiktok-automation",
  "version": "1.0.0",
  "description": "Automation service that monitors a Google Sheet for new rows and schedules TikTok video posts via Buffer",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest --run"
  },
  "keywords": [
    "tiktok",
    "buffer",
    "google-sheets",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "google-spreadsheet": "^5.3.0",
    "graphql-request": "^7.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "fast-check": "^4.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
